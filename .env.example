# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string — include the database name in the path (/reckon)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/reckon?appName=<AppName>

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Minimum 32 characters each. Generate with: openssl rand -hex 32
JWT_SECRET=<min-32-char-random-string>
JWT_REFRESH_SECRET=<min-32-char-random-string>

# Token lifetimes (defaults shown — override if needed)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com — required for monthly digest emails and budget alerts
RESEND_API_KEY=re_<your-resend-api-key>
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Shared secret for /api/subscribe/activate — minimum 16 chars
# Generate with: openssl rand -hex 24
WEBHOOK_SECRET=<min-16-char-random-string>

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# Bearer token for /api/cron/monthly-digest — minimum 16 chars
# Generate with: openssl rand -hex 24
# Add to Vercel: Settings → Cron Jobs → Authorization Header
CRON_SECRET=<min-16-char-random-string>

# ── AI (optional) ─────────────────────────────────────────────────────────────
# Anthropic API key — only needed if AI insight features are enabled
ANTHROPIC_API_KEY=sk-ant-<your-key>
